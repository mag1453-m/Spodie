# ─────────────────────────────────────────────
# SPODIE — Ortam Değişkenleri Şablonu
# Bu dosyayı .env.local olarak kopyala ve değerleri doldur.
# .env.local ASLA git'e gönderilmez (.gitignore'da).
# ─────────────────────────────────────────────

# --- Spotify Developer Dashboard'dan ---
SPOTIFY_CLIENT_ID=buraya_client_id
SPOTIFY_CLIENT_SECRET=buraya_client_secret

# OAuth dönüş adresi. Lokalde bu kalsın.
# Vercel'e deploy edince https://<projen>.vercel.app/api/auth/callback yap
# ve Spotify Dashboard'a da AYNI adresi ekle.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback

# --- Supabase (Project Settings > API) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon_public_key

# service_role anahtarı — SADECE sunucu tarafı. ASLA tarayıcıya sızdırma.
# Cron job ve token saklama bunu kullanır (RLS'i bypass eder).
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_key

# --- Güvenlik ---
# Token'ları DB'de şifrelemek için rastgele 32+ karakter.
# Üretmek için: openssl rand -base64 32   (ya da herhangi uzun rastgele dize)
TOKEN_ENCRYPTION_KEY=buraya_uzun_rastgele_anahtar_en_az_32_karakter

# Cron route'unu korumak için gizli anahtar (Vercel Cron bunu Authorization header'da gönderir)
CRON_SECRET=buraya_rastgele_cron_secret

# Sitenin kendi adresi (login yönlendirmeleri için). Lokalde:
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
